{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/dist/bin/claude-watchdog hook SessionStart" }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/dist/bin/claude-watchdog hook SessionEnd" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/dist/bin/claude-watchdog hook UserPromptSubmit" }] }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/dist/bin/claude-watchdog hook PreToolUse AskUserQuestion" }]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/dist/bin/claude-watchdog hook PreToolUse ExitPlanMode" }]
      }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/dist/bin/claude-watchdog hook Stop" }] }
    ]
  }
}
