#!/usr/bin/env bash
# Unified entry point for claude-code-monitor
# Used by both hooks and direct CLI invocation
# Compiles on first use or when source changes, then runs the compiled binary

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
COMPILED="${SCRIPT_DIR}/.compiled"

# Rebuild if binary is missing or source has changed
if [[ ! -x "$COMPILED" ]] || [[ -n "$(find "$ROOT_DIR/src" "$ROOT_DIR/package.json" -newer "$COMPILED" 2>/dev/null)" ]]; then
  bun build --compile --minify "${ROOT_DIR}/src/cli.ts" --outfile "$COMPILED" >&2
fi

exec "$COMPILED" "$@"
